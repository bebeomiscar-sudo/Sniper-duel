local function getScreenCenter()
    return Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
end

local function angleDiff(f, t)
    local d = t - f
    return ((d + math.pi) % (math.pi * 2)) - math.pi
end

local function isSameTeam(p)
    local same = false
    pcall(function() same = p.Team ~= nil and LP.Team ~= nil and p.Team == LP.Team end)
    pcall(function()
        local mi = LP:GetAttribute("TeamID")
        local ti = p:GetAttribute("TeamID")
        if mi ~= nil and ti ~= nil then same = (mi == ti) end
    end)
    return same
end

local visRayParams = RaycastParams.new()
visRayParams.FilterType = Enum.RaycastFilterType.Exclude

local function isVisible(origin, part)
    if not part then return false end
    local ok, res = pcall(function()
        visRayParams.FilterDescendantsInstances = {LP.Character, part.Parent}
        local dir = part.Position - origin
        local hit = Workspace:Raycast(origin, dir, visRayParams)
        return hit == nil or hit.Instance:IsDescendantOf(part.Parent)
    end)
    return ok and res or false
end

local function getEffectiveAimbotFOV()
    local f = AimbotCFG.FOV
    if AimbotCFG.DynamicFOV then f = f * (camera.FieldOfView / 70) end
    return f
end

local function isInAimbotFOV(part)
    if not part then return false end
    local sp, on = camera:WorldToViewportPoint(part.Position)
    if not on then return false end
    return (Vector2.new(sp.X, sp.Y) - getScreenCenter()).Magnitude <= getEffectiveAimbotFOV()
end

-- ═══════════════════════════════════════════
-- AIMBOT
-- Uses CFrame camera manipulation instead of
-- CameraController since Sniper Duel doesn't
-- expose one. Works on both PC and Mobile.
-- ═══════════════════════════════════════════
local lockedTarget  = nil
local lockTimer     = 0
local reactionTimer = 0
local isInReaction  = false

local delayedPosX = nil
local delayedPosY = nil
local delayedPosZ = nil

local function resetDelayedPos()
    delayedPosX = nil
    delayedPosY = nil
    delayedPosZ = nil
end

local function getSmoothedPos(part, dt)
    if not part or not part.Parent then
        resetDelayedPos()
        return nil
    end

    local real = part.Position

    -- Prediction: lead target by velocity
    pcall(function()
        local hrp = part.Parent:FindFirstChild("HumanoidRootPart")
        if hrp and AimbotCFG.Prediction > 0 then
            real = real + hrp.AssemblyLinearVelocity * AimbotCFG.Prediction
        end
    end)

    if not delayedPosX then
        delayedPosX = real.X
        delayedPosY = real.Y
        delayedPosZ = real.Z
        return real
    end

    local frames = 60 * dt
    local xA = math.clamp((1 - AimbotCFG.XSmooth) * (1 + frames), 0.01, 1)
    local yA = math.clamp((1 - AimbotCFG.YSmooth) * (1 + frames), 0.01, 1)
    local zA = math.clamp((1 - AimbotCFG.ZSmooth) * (1 + frames), 0.01, 1)

    delayedPosX = delayedPosX + (real.X - delayedPosX) * xA
    delayedPosY = delayedPosY + (real.Y - delayedPosY) * yA
    delayedPosZ = delayedPosZ + (real.Z - delayedPosZ) * zA

    return Vector3.new(delayedPosX, delayedPosY, delayedPosZ)
end

local function isTargetValid(part)
    if not part or not part.Parent then return false end
    local hum = part.Parent:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if not isInAimbotFOV(part) then return false end
    if AimbotCFG.VisibleCheck and not isVisible(camera.CFrame.Position, part) then return false end
    if AimbotCFG.TeamCheck then
        local p = Players:GetPlayerFromCharacter(part.Parent)
        if p and isSameTeam(p) then return false end
    end
    return true
end

local function findAimbotTarget()
    local center = getScreenCenter()
    local fov    = getEffectiveAimbotFOV()
    local best, bd = nil, fov
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LP then continue end
        if AimbotCFG.TeamCheck and isSameTeam(p) then continue end
        local ch = p.Character
        if not ch then continue end
        local hum = ch:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        local part = getBestPart(ch, AimbotCFG.TargetPart)
        if not part then continue end
        local sp, on = camera:WorldToViewportPoint(part.Position)
        if not on then continue end
        local d = (Vector2.new(sp.X, sp.Y) - center).Magnitude
        if d > fov then continue end
        if AimbotCFG.VisibleCheck and not isVisible(camera.CFrame.Position, part) then continue end
        if d < bd then bd = d; best = part end
    end
    return best
end

-- CFrame-based camera rotation
-- Works for PC and Mobile since it directly
-- sets the camera CFrame without needing any
-- game-specific controller module
local function rotateCameraToward(targetPos, dt)
    local sm = math.clamp(1 / math.max(AimbotCFG.Smoothness, 0.1), 0.01, 1)
    local camPos   = camera.CFrame.Position
    local dir      = (targetPos - camPos).Unit
    local targetCF = CFrame.new(camPos, camPos + dir)

    -- Smoothly interpolate current camera CFrame toward target
    local newCF = camera.CFrame:Lerp(targetCF, sm)

    -- Use pcall in case game locks the camera
    pcall(function()
        camera.CFrame = newCF
    end)
end

