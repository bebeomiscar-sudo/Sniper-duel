RunService.RenderStepped:Connect(function(dt)
    -- Silent Aim FOV circle
    if State.SilentAim then
        local center = Camera.ViewportSize / 2
        fovCircle.Position = Vector2.new(center.X, center.Y)
        fovCircle.Radius   = State.SilentFOV
        local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        local origin = myRoot and myRoot.Position or Camera.CFrame.Position
        fovCircle.Color = getSilentTarget(origin) ~= nil
            and Color3.fromRGB(255, 50, 50)
            or  Color3.fromRGB(0, 200, 255)
    end

    -- Aimbot
    if State.Aimbot and not State.Ragebot then
        local target = getClosestToMouse(State.AimbotFOV)
        if target then
            local camPos = wspace.CurrentCamera.CFrame.Position
            local lookCF = CFrame.lookAt(camPos, target.Position)
            if State.AimbotSmooth then
                local rx, ry, _ = lookCF:ToOrientation()
                local tRot = Vector2.new(rx, ry)
                local cRot = CameraController.Rotation
                local diff = tRot - cRot
                if diff.Y >  math.pi then diff = Vector2.new(diff.X, diff.Y - math.pi * 2) end
                if diff.Y < -math.pi then diff = Vector2.new(diff.X, diff.Y + math.pi * 2) end
                CameraController:SetRotation(cRot + diff * math.clamp(dt * State.AimbotSpeed * 10, 0, 1))
            else
                CameraController:MimicRotation(lookCF)
            end
        end
    end

    -- ESP
    if State.ESP then
        local models   = FighterController:GetFighterModels(true)
        local modelSet = {}
        for _, model in pairs(models) do
            modelSet[model] = true
            if not ESPObjects[model] or not ESPObjects[model].Parent then
                local h            = Instance.new("Highlight")
                h.FillColor        = State.ESPColor
                h.OutlineColor     = Color3.fromRGB(255, 255, 255)
                h.FillTransparency = State.ESPTransp
                h.Adornee          = model
                h.Parent           = CoreGui
                ESPObjects[model]  = h
            end
        end
        for model, h in pairs(ESPObjects) do
            if not modelSet[model] then
                if h and h.Parent then h:Destroy() end
                ESPObjects[model] = nil
            end
        end
    end
end)

RunService.Heartbeat:Connect(function()

    -- Ragebot (with wallbang support)
    if State.Ragebot then
        pcall(function()
            local char = lp.Character
            if not char then return end
            local root = char:FindFirstChild("HumanoidRootPart")
            if not root then return end
            if not FighterController or not FighterController.LocalFighter then return end
            local item = FighterController.LocalFighter.EquippedItem
            if not item then return end

            local targetPart, targetChar = rageGetClosest()
            if not targetPart or not targetChar then return end

            local cam = wspace.CurrentCamera.CFrame
            local cameradata = {}

            if State.Wallbang then
                -- WALLBANG MODE: place origin next to target, desync char position
                local wbData = buildWBCameraData(targetChar)
                if wbData then
                    cameradata = wbData
                end
            else
                -- NORMAL MODE: calculate unobstructed angle
                local manip, height = rageCalculatePoint(cam.Position, targetPart.Position, targetChar)
                if not manip then return end
                local shootPos = (height == nil) and manip or cam.Position
                cameradata[utf8.char(1)] = {
                    [utf8.char(0)] = Utility:EncodeCFrame(
                        CFrame.new(shootPos.X, shootPos.Y + (height or 0), shootPos.Z)
                        * CFrame.Angles(CFrame.lookAt(shootPos, targetPart.Position):ToOrientation())
                    ),
                    [utf8.char(1)] = height
                        and Utility:EncodeCFrame(
                            CFrame.new(targetPart.Position)
                            * CFrame.Angles(CFrame.lookAt(shootPos, targetPart.Position):ToOrientation())
                        )
                        or Utility:EncodeCFrame(
                            CFrame.new(shootPos.X, shootPos.Y + (height or 0), shootPos.Z)
                            * CFrame.Angles(CFrame.lookAt(shootPos, targetPart.Position):ToOrientation())
                        ),
                    [utf8.char(2)] = targetPart,
                    [utf8.char(3)] = Utility:EncodeCFrame(
                        targetPart.CFrame:ToObjectSpace(CFrame.new(targetPart.Position))
                    )
                }
            end

            rs.Remotes.Replication.Fighter.UseItem:FireServer(
                item:Get("ObjectID"),
                EnumLibrary:ToEnum("StartShooting"),
                cameradata,
                nil
            )
        end)
    end

    -- Auto-TP
    if State.AutoTP then
        local now = tick()
        if now % 2 < 0.05 then updateTPList() end
        if #tpPlayerList > 0 then
            if now - lastCycle >= 3 then
                tpCurrentIndex = (tpCurrentIndex % #tpPlayerList) + 1
                lastCycle = now
            end
            if now - lastTeleport >= 0.5 then
                local target = tpPlayerList[tpCurrentIndex]
                if target then tpToHead(target) end
                lastTeleport = now
            end
        end
    end
end)

