local espObjects = {}

local function removeESPFor(p)
    if not espObjects[p] then return end
    local obj = espObjects[p]
    pcall(function() if obj.box    then obj.box:Destroy()    end end)
    pcall(function() if obj.name   then obj.name:Remove()    end end)
    pcall(function() if obj.health then obj.health:Remove()  end end)
    pcall(function() if obj.dist   then obj.dist:Remove()    end end)
    pcall(function() if obj.line   then obj.line:Remove()    end end)
    pcall(function() if obj.hpbar  then obj.hpbar:Remove()   end end)
    pcall(function() if obj.hpbarbg then obj.hpbarbg:Remove() end end)
    espObjects[p] = nil
end

local function clearAllESP()
    for p in pairs(espObjects) do
        removeESPFor(p)
    end
end

Players.PlayerRemoving:Connect(removeESPFor)

local function makeESPFor(p)
    if espObjects[p] then return end
    local obj = {}

    obj.box = Instance.new("SelectionBox")
    obj.box.Color3              = ESPConfig.BoxColor
    obj.box.LineThickness       = 0.04
    obj.box.SurfaceTransparency = 1
    obj.box.Parent              = Workspace

    obj.name = Drawing.new("Text")
    obj.name.Size    = 14
    obj.name.Outline = true
    obj.name.Center  = true
    obj.name.Visible = false
    obj.name.Color   = ESPConfig.NameColor
    obj.name.Font    = 2

    obj.health = Drawing.new("Text")
    obj.health.Size    = 13
    obj.health.Outline = true
    obj.health.Center  = true
    obj.health.Visible = false
    obj.health.Font    = 2

    obj.dist = Drawing.new("Text")
    obj.dist.Size    = 12
    obj.dist.Outline = true
    obj.dist.Center  = true
    obj.dist.Visible = false
    obj.dist.Color   = Color3.fromRGB(200, 200, 200)
    obj.dist.Font    = 2

    obj.line = Drawing.new("Line")
    obj.line.Thickness = 1
    obj.line.Visible   = false
    obj.line.Color     = ESPConfig.LineColor

    obj.hpbarbg = Drawing.new("Square")
    obj.hpbarbg.Filled      = true
    obj.hpbarbg.Visible     = false
    obj.hpbarbg.Color       = Color3.fromRGB(30, 30, 30)
    obj.hpbarbg.Transparency = 0.5

    obj.hpbar = Drawing.new("Square")
    obj.hpbar.Filled      = true
    obj.hpbar.Visible     = false
    obj.hpbar.Transparency = 0.15

    espObjects[p] = obj
end

local function updateESP()
    if not ESPConfig.Enabled then clearAllESP(); return end

    local myPos  = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    local center = getScreenCenter()

    for _, p in ipairs(Players:GetPlayers()) do
        if p == LP then continue end

        local ch   = p.Character
        local hrp  = ch and ch:FindFirstChild("HumanoidRootPart")
        local hum  = ch and ch:FindFirstChildOfClass("Humanoid")
        local head = ch and ch:FindFirstChild("Head")

        if not ch or not hrp or not hum or hum.Health <= 0 then
            removeESPFor(p)
            continue
        end

        local dist = myPos and (myPos.Position - hrp.Position).Magnitude or 0
        if dist > ESPConfig.MaxDist then
            removeESPFor(p)
            continue
        end

        makeESPFor(p)
        local obj = espObjects[p]
        if not obj then continue end

        -- Box color
        local boxColor = ESPConfig.BoxColor
        if ESPConfig.TeamColor then
            boxColor = isSameTeam(p)
                and Color3.fromRGB(50, 100, 255)
                or  Color3.fromRGB(255, 50, 50)
        end

        -- SelectionBox
        if ESPConfig.ShowBox then
            obj.box.Adornee = ch
            obj.box.Color3  = boxColor
        else
            obj.box.Adornee = nil
        end

        local headPos      = head and head.Position or hrp.Position
        local sp, onScreen = camera:WorldToViewportPoint(headPos)
        local sp2, _       = camera:WorldToViewportPoint(hrp.Position)
        local screenPos    = Vector2.new(sp.X,  sp.Y)
        local screenPos2   = Vector2.new(sp2.X, sp2.Y)

        local hpPct    = math.clamp(hum.Health / math.max(hum.MaxHealth, 1), 0, 1)
        local hpColor  = Color3.fromRGB(
            math.floor(255 * (1 - hpPct)),
            math.floor(255 * hpPct),
            50
        )

        -- Name
        obj.name.Visible  = ESPConfig.ShowName and onScreen
        obj.name.Text     = p.DisplayName ~= "" and p.DisplayName or p.Name
        obj.name.Position = screenPos + Vector2.new(0, -24)
        obj.name.Color    = ESPConfig.NameColor

        -- Health text
        obj.health.Visible  = ESPConfig.ShowHealth and onScreen
        obj.health.Text     = string.format("%d HP", math.floor(hum.Health))
        obj.health.Position = screenPos + Vector2.new(0, -38)
        obj.health.Color    = hpColor

        -- Distance
        obj.dist.Visible  = ESPConfig.ShowDist and onScreen
        obj.dist.Text     = string.format("%.0f studs", dist)
        obj.dist.Position = screenPos2 + Vector2.new(0, 12)

        -- Health bar
        local barW  = 4
        local barH  = 40
        local barX  = screenPos.X - 34
        local barY  = screenPos.Y - barH / 2

        obj.hpbarbg.Visible  = ESPConfig.ShowHealth and onScreen
        obj.hpbarbg.Position = Vector2.new(barX, barY)
        obj.hpbarbg.Size     = Vector2.new(barW, barH)

        obj.hpbar.Visible    = ESPConfig.ShowHealth and onScreen
        obj.hpbar.Position   = Vector2.new(barX, barY + barH * (1 - hpPct))
        obj.hpbar.Size       = Vector2.new(barW, barH * hpPct)
        obj.hpbar.Color      = hpColor

        -- Tracer line
        obj.line.Visible = ESPConfig.ShowLines and onScreen
        obj.line.From    = Vector2.new(center.X, camera.ViewportSize.Y)
        obj.line.To      = screenPos
        obj.line.Color   = ESPConfig.LineColor
    end

    -- Cleanup disconnected players
    for p in pairs(espObjects) do
        local found = false
        for _, v in ipairs(Players:GetPlayers()) do
            if v == p then found = true; break end
        end
        if not found then removeESPFor(p) end
    end
end

