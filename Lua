local espObjects = {}

local function removeESP(p)
    local obj = espObjects[p]
    if not obj then return end
    pcall(function() if obj.box    then obj.box:Destroy()    end end)
    pcall(function() if obj.name   then obj.name:Remove()    end end)
    pcall(function() if obj.health then obj.health:Remove()  end end)
    pcall(function() if obj.dist   then obj.dist:Remove()    end end)
    pcall(function() if obj.line   then obj.line:Remove()    end end)
    pcall(function() if obj.hpbar  then obj.hpbar:Remove()   end end)
    pcall(function() if obj.hpbg   then obj.hpbg:Remove()    end end)
    espObjects[p] = nil
end

local function clearESP()
    for p in pairs(espObjects) do removeESP(p) end
end

Players.PlayerRemoving:Connect(removeESP)

local function makeESP(p)
    if espObjects[p] then return end
    local o = {}

    o.box = Instance.new("SelectionBox")
    o.box.LineThickness       = 0.04
    o.box.SurfaceTransparency = 1
    o.box.Parent              = Workspace

    o.name   = Drawing.new("Text")
    o.name.Size    = 14
    o.name.Outline = true
    o.name.Center  = true
    o.name.Visible = false
    o.name.Font    = 2

    o.health = Drawing.new("Text")
    o.health.Size    = 13
    o.health.Outline = true
    o.health.Center  = true
    o.health.Visible = false
    o.health.Font    = 2

    o.dist   = Drawing.new("Text")
    o.dist.Size    = 12
    o.dist.Outline = true
    o.dist.Center  = true
    o.dist.Visible = false
    o.dist.Color   = Color3.fromRGB(200, 200, 200)
    o.dist.Font    = 2

    o.line   = Drawing.new("Line")
    o.line.Thickness = 1
    o.line.Visible   = false

    o.hpbg   = Drawing.new("Square")
    o.hpbg.Filled      = true
    o.hpbg.Visible     = false
    o.hpbg.Color       = Color3.fromRGB(20, 20, 20)
    o.hpbg.Transparency = 0.4

    o.hpbar  = Drawing.new("Square")
    o.hpbar.Filled      = true
    o.hpbar.Visible     = false
    o.hpbar.Transparency = 0.1

    espObjects[p] = o
end

local function updateESP()
    if not ESPConfig.Enabled then clearESP(); return end

    local myHRP  = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    local center = getScreenCenter()

    for _, p in ipairs(Players:GetPlayers()) do
        if p == LP then continue end

        local ch   = p.Character
        local hrp  = ch and ch:FindFirstChild("HumanoidRootPart")
        local hum  = ch and ch:FindFirstChildOfClass("Humanoid")
        local head = ch and ch:FindFirstChild("Head")

        if not ch or not hrp or not hum or hum.Health <= 0 then
            removeESP(p); continue
        end

        local dist = myHRP and (myHRP.Position - hrp.Position).Magnitude or 0
        if dist > ESPConfig.MaxDist then removeESP(p); continue end

        makeESP(p)
        local o = espObjects[p]
        if not o then continue end

        local col = ESPConfig.BoxColor
        if ESPConfig.TeamColor then
            col = isSameTeam(p)
                and Color3.fromRGB(50, 100, 255)
                or  Color3.fromRGB(255, 50,  50)
        end

        if ESPConfig.ShowBox then
            o.box.Adornee = ch
            o.box.Color3  = col
        else
            o.box.Adornee = nil
        end

        local hp     = math.clamp(hum.Health / math.max(hum.MaxHealth, 1), 0, 1)
        local hpCol  = Color3.fromRGB(
            math.floor(255 * (1 - hp)),
            math.floor(255 * hp),
            50
        )

        local headPos      = head and head.Position or hrp.Position
        local sp,  onScr   = camera:WorldToViewportPoint(headPos)
        local sp2, _       = camera:WorldToViewportPoint(hrp.Position)
        local sPos         = Vector2.new(sp.X,  sp.Y)
        local sPos2        = Vector2.new(sp2.X, sp2.Y)

        o.name.Visible   = ESPConfig.ShowName   and onScr
        o.name.Text      = p.DisplayName ~= "" and p.DisplayName or p.Name
        o.name.Position  = sPos + Vector2.new(0, -24)
        o.name.Color     = ESPConfig.NameColor

        o.health.Visible  = ESPConfig.ShowHealth and onScr
        o.health.Text     = string.format("%d HP", math.floor(hum.Health))
        o.health.Position = sPos + Vector2.new(0, -38)
        o.health.Color    = hpCol

        o.dist.Visible   = ESPConfig.ShowDist   and onScr
        o.dist.Text      = string.format("%.0f studs", dist)
        o.dist.Position  = sPos2 + Vector2.new(0, 12)

        local bW, bH = 4, 40
        local bX     = sPos.X - 34
        local bY     = sPos.Y - bH / 2

        o.hpbg.Visible   = ESPConfig.ShowHealth and onScr
        o.hpbg.Position  = Vector2.new(bX, bY)
        o.hpbg.Size      = Vector2.new(bW, bH)

        o.hpbar.Visible  = ESPConfig.ShowHealth and onScr
        o.hpbar.Position = Vector2.new(bX, bY + bH * (1 - hp))
        o.hpbar.Size     = Vector2.new(bW, bH * hp)
        o.hpbar.Color    = hpCol

        o.line.Visible = ESPConfig.ShowLines and onScr
        o.line.From    = Vector2.new(center.X, camera.ViewportSize.Y)
        o.line.To      = sPos
        o.line.Color   = ESPConfig.LineColor
    end

    for p in pairs(espObjects) do
        local ok = false
        for _, v in ipairs(Players:GetPlayers()) do
            if v == p then ok = true; break end
        end
        if not ok then removeESP(p) end
    end
end

