-- MAIN LOOP
-- ═══════════════════════════════════════════
RunService.RenderStepped:Connect(function(dt)
    camera = Workspace.CurrentCamera
    local center = getScreenCenter()

    -- Aimbot FOV circle
    fovCircle.Position = center
    fovCircle.Radius   = getEffectiveAimbotFOV()
    fovCircle.Visible  = AimbotCFG.DrawFOV and AimbotCFG.On and AimbotCFG.FOVStyle ~= "Invisible"

    -- SA FOV circle
    saFovCircle.Position = center
    saFovCircle.Radius   = SACFG.FOV
    if SACFG.On and SACFG.DrawFOV then
        local myRoot    = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        local hasTarget = saGetTarget(myRoot and myRoot.Position or camera.CFrame.Position) ~= nil
        saFovCircle.Color   = hasTarget
            and Color3.fromRGB(255, 50,  50)
            or  Color3.fromRGB(0,   200, 255)
        saFovCircle.Visible = true
    else
        saFovCircle.Visible = false
    end

    -- ESP
    updateESP()

    -- Aimbot
    if AimbotCFG.On then
        if isInReaction then
            reactionTimer = reactionTimer - dt
            if reactionTimer <= 0 then isInReaction = false end
        end

        if not isInReaction then
            -- Validate current lock
            if lockedTarget and not isTargetValid(lockedTarget) then
                lockedTarget = nil
                lockTimer    = 0
                resetDelayedPos()
            end

            -- Find new target
            if not lockedTarget then
                local newT = findAimbotTarget()
                if newT then
                    lockedTarget  = newT
                    lockTimer     = 0
                    isInReaction  = AimbotCFG.ReactionTime > 0
                    reactionTimer = AimbotCFG.ReactionTime / 1000
                    resetDelayedPos()
                end
            end

            -- Apply rotation
            if lockedTarget then
                lockTimer = lockTimer + dt
                if lockTimer > AimbotCFG.ForgotTime then
                    lockedTarget = nil
                    lockTimer    = 0
                    resetDelayedPos()
                elseif isInAimbotFOV(lockedTarget) then
                    local aimPos = getSmoothedPos(lockedTarget, dt)
                    if aimPos then
                        rotateCameraToward(aimPos, dt)
                    end
                else
                    lockedTarget = nil
                    lockTimer    = 0
                    resetDelayedPos()
                end
            end
        end
    end
end)

