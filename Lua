-- ═══════════════════════════════════════════
-- SILENT AIM — util.Raycast hook
-- Same method as Rivals script.
-- Redirects bullet raycast to nearest valid
-- target head within FOV.
-- HitChance: % chance per shot to redirect.
-- PartBias: which part to aim at server-side.
-- No distance limit — sniper game, shots are long.
-- ═══════════════════════════════════════════

local saFovCircle = Drawing.new("Circle")
saFovCircle.NumSides     = 64
saFovCircle.Visible      = false
saFovCircle.Color        = Color3.fromRGB(0, 200, 255)
saFovCircle.Thickness    = 1.5
saFovCircle.Transparency = 0.7
saFovCircle.Filled       = false

local saHookApplied = false

-- SA target finder — no distance check (sniper range)
local function saGetTarget(origin)
    local center   = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
    local best, bd = nil, math.huge
    local myChar   = LP.Character

    for _, p in pairs(Players:GetPlayers()) do
        if p == LP then continue end
        if SACFG.TeamCheck and isSameTeam(p) then continue end
        local char = p.Character
        if not char or char == myChar then continue end

        -- Use PartBias to pick target part
        local targetPart = getBestPart(char, SACFG.PartBias)
        if not targetPart then continue end

        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end

        local sp, vis = camera:WorldToViewportPoint(targetPart.Position)
        if not vis then continue end

        local d = (Vector2.new(sp.X, sp.Y) - center).Magnitude
        if d < SACFG.FOV and d < bd then
            bd   = d
            best = targetPart
        end
    end

    return best
end

local function applySAHook()
    if saHookApplied then return end
    if not util_mod then
        Library:Notify("SA: util_mod not found", 4)
        return
    end

    -- Hook util.Raycast
    -- When player fires, game calls util.Raycast
    -- We replace origin direction with direction toward target
    local origRaycast = util_mod.Raycast
    util_mod.Raycast = function(self, origin, direction, distance, ...)
        if SACFG.On then
            -- HitChance check — random per shot
            if math.random(1, 100) <= SACFG.HitChance then
                local target = saGetTarget(origin)
                if target then
                    return origRaycast(self, origin, target.Position, distance, ...)
                end
            end
        end
        return origRaycast(self, origin, direction, distance, ...)
    end

    -- Block flash/smoke/blind particles (same as Rivals)
    local origParticles = util_mod.PlayParticles
    if origParticles then
        util_mod.PlayParticles = function(self, obj)
            if typeof(obj) == "Instance" then
                local n = obj.Name:lower()
                if n:find("flash") or n:find("smoke") or n:find("blind") or n:find("muzzle") then
                    return
                end
            end
            return origParticles(self, obj)
        end
    end

    saHookApplied = true
    Library:Notify("SA hook applied", 2)
end

local function startSA()
    applySAHook()
    saFovCircle.Visible = SACFG.DrawFOV
end

local function stopSA()
    SACFG.On            = false
    saFovCircle.Visible = false
end

-- ═══════════════════════════════════════════
-- ESP SYSTEM
-- Features:
--   - Box (SelectionBox)
--   - Name tag
--   - Health bar
--   - Distance label
--   - Highlight color based on health
-- ═══════════════════════════════════════════
local ESPConfig = {
    Enabled        = false,
    ShowBox        = true,
    ShowName       = true,
    ShowHealth     = true,
    ShowDist       = true,
    ShowLines      = false,
    BoxColor       = Color3.fromRGB(255, 50,  50),
    NameColor      = Color3.fromRGB(255, 255, 255),
    HealthColor    = Color3.fromRGB(50,  255, 100),
    LineColor      = Color3.fromRGB(255, 200, 0),
    TeamColor      = false, -- color by team
    MaxDist        = 2000,
}

local espObjects = {}

local function removeESPFor(p)
    if not espObjects[p] then return end
    local obj = espObjects[p]
    if obj.box     and obj.box.Parent     then obj.box:Destroy()     end
    if obj.name    and obj.name.Parent    then obj.name:Destroy()    end
    if obj.health  and obj.health.Parent  then obj.health:Destroy()  end
    if obj.dist    and obj.dist.Parent    then obj.dist:Destroy()    end
    if obj.line    then obj.line:Remove() end
    if obj.hpbar   then obj.hpbar:Remove() end
    espObjects[p] = nil
end

local function clearAllESP()
    for p in pairs(espObjects) do
        removeESPFor(p)
    end
end

local function makeESPFor(p)
    if espObjects[p] then return end
    local obj = {}

    -- SelectionBox
    if ESPConfig.ShowBox then
        local box = Instance.new("SelectionBox")
        box.Color3              = ESPConfig.BoxColor
        box.LineThickness       = 0.04
        box.SurfaceTransparency = 1
        box.Parent              = Workspace
        obj.box = box
    end

    -- Name tag (Drawing)
    obj.name = Drawing.new("Text")
    obj.name.Size    = 14
    obj.name.Outline = true
    obj.name.Center  = true
    obj.name.Visible = false
    obj.name.Color   = ESPConfig.NameColor
    obj.name.Font    = 2

    -- Health text
    obj.health = Drawing.new("Text")
    obj.health.Size    = 13
    obj.health.Outline = true
    obj.health.Center  = true
    obj.health.Visible = false
    obj.health.Font    = 2

    -- Distance text
    obj.dist = Drawing.new("Text")
    obj.dist.Size    = 12
    obj.dist.Outline = true
    obj.dist.Center  = true
    obj.dist.Visible = false
    obj.dist.Color   = Color3.fromRGB(200, 200, 200)
    obj.dist.Font    = 2

    -- Line from screen bottom to player
    obj.line = Drawing.new("Line")
    obj.line.Thickness = 1
    obj.line.Visible   = false
    obj.line.Color     = ESPConfig.LineColor

    -- Health bar (rectangle)
    obj.hpbar     = Drawing.new("Square")
    obj.hpbar.Filled      = true
    obj.hpbar.Visible     = false
    obj.hpbar.Color       = ESPConfig.HealthColor
    obj.hpbar.Transparency = 0.8

    obj.hpbarbg   = Drawing.new("Square")
    obj.hpbarbg.Filled      = true
    obj.hpbarbg.Visible     = false
    obj.hpbarbg.Color       = Color3.fromRGB(30, 30, 30)
    obj.hpbarbg.Transparency = 0.6

    espObjects[p] = obj
end

local function updateESP()
    if not ESPConfig.Enabled then clearAllESP(); return end

    local myPos  = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    local center = getScreenCenter()

    for _, p in ipairs(Players:GetPlayers()) do
        if p == LP then continue end

        local ch  = p.Character
        local hrp = ch and ch:FindFirstChild("HumanoidRootPart")
        local hum = ch and ch:FindFirstChildOfClass("Humanoid")
        local head = ch and ch:FindFirstChild("Head")

        -- Remove ESP if player invalid
        if not ch or not hrp or not hum or hum.Health <= 0 then
            removeESPFor(p)
            continue
        end

        -- Distance check
        local dist = myPos and (myPos.Position - hrp.Position).Magnitude or 0
        if dist > ESPConfig.MaxDist then
            removeESPFor(p)
            continue
        end

        makeESPFor(p)
        local obj = espObjects[p]
        if not obj then continue end

        -- Box color (team or config)
        local boxColor = ESPConfig.BoxColor
        if ESPConfig.TeamColor then
            boxColor = isSameTeam(p)
                and Color3.fromRGB(50, 100, 255)
                or  Color3.fromRGB(255, 50, 50)
        end

        -- Update SelectionBox
        if obj.box then
            obj.box.Adornee = ch
            obj.box.Color3  = boxColor
        end

        -- Screen position of head
        local sp, onScreen = camera:WorldToViewportPoint(head and head.Position or hrp.Position)
        local sp2, _       = camera:WorldToViewportPoint(hrp.Position)

        local screenPos = Vector2.new(sp.X, sp.Y)
        local screenPos2 = Vector2.new(sp2.X, sp2.Y)

        -- Name tag (above head)
        obj.name.Visible = ESPConfig.ShowName and onScreen
        if ESPConfig.ShowName and onScreen then
            obj.name.Text     = p.DisplayName or p.Name
            obj.name.Position = screenPos + Vector2.new(0, -22)
            obj.name.Color    = ESPConfig.NameColor
        end

        -- Health text
        local hpPct = hum.Health / hum.MaxHealth
        local hpColor = Color3.fromRGB(
            math.floor(255 * (1 - hpPct)),
            math.floor(255 * hpPct),
            50
        )
        obj.health.Visible = ESPConfig.ShowHealth and onScreen
        if ESPConfig.ShowHealth and onScreen then
            obj.health.Text     = string.format("HP: %d/%d", math.floor(hum.Health), math.floor(hum.MaxHealth))
            obj.health.Position = screenPos + Vector2.new(0, -36)
            obj.health.Color    = hpColor
        end

        -- Distance label
        obj.dist.Visible = ESPConfig.ShowDist and onScreen
        if ESPConfig.ShowDist and onScreen then
            obj.dist.Text     = string.format("%.0f studs", dist)
            obj.dist.Position = screenPos2 + Vector2.new(0, 10)
        end

        -- Health bar (vertical bar left of player)
        local barWidth  = 4
        local barHeight = 40
        local barX      = screenPos.X - 30
        local barY      = screenPos.Y - barHeight / 2

        obj.hpbarbg.Visible     = ESPConfig.ShowHealth and onScreen
        obj.hpbarbg.Position    = Vector2.new(barX, barY)
        obj.hpbarbg.Size        = Vector2.new(barWidth, barHeight)

        obj.hpbar.Visible       = ESPConfig.ShowHealth and onScreen
        obj.hpbar.Position      = Vector2.new(barX, barY + barHeight * (1 - hpPct))
        obj.hpbar.Size          = Vector2.new(barWidth, barHeight * hpPct)
        obj.hpbar.Color         = hpColor

        -- Tracer line from bottom center to player
        obj.line.Visible = ESPConfig.ShowLines and onScreen
        if ESPConfig.ShowLines and onScreen then
            obj.line.From  = Vector2.new(center.X, camera.ViewportSize.Y)
            obj.line.To    = screenPos
            obj.line.Color = ESPConfig.LineColor
        end
    end

    -- Cleanup for disconnected players
    for p in pairs(espObjects) do
        local found = false
        for _, v in ipairs(Players:GetPlayers()) do
            if v == p then found = true; break end
        end
        if not found then removeESPFor(p) end
    end
end

