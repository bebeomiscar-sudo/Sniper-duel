-- ═══════════════════════════════════════════
-- SILENT AIM
-- ═══════════════════════════════════════════
local saHooked = false

local function saGetTarget(origin)
    local center   = getScreenCenter()
    local best, bd = nil, math.huge
    local myChar   = LP.Character
    for _, p in pairs(Players:GetPlayers()) do
        if p == LP then continue end
        if SACFG.TeamCheck and isSameTeam(p) then continue end
        local char = p.Character
        if not char or char == myChar then continue end
        local part = getBestPart(char, SACFG.PartBias)
        if not part then continue end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        local sp, vis = camera:WorldToViewportPoint(part.Position)
        if not vis then continue end
        local d = (Vector2.new(sp.X, sp.Y) - center).Magnitude
        if d < SACFG.FOV and d < bd then
            bd = d; best = part
        end
    end
    return best
end

local function applySAHook()
    if saHooked then return end
    if not util_mod then
        Library:Notify("SA FAILED: util_mod not found", 5)
        return
    end

    local origRC = util_mod.Raycast
    util_mod.Raycast = function(self, origin, direction, distance, ...)
        if SACFG.On and math.random(1, 100) <= SACFG.HitChance then
            local t = saGetTarget(origin)
            if t then
                return origRC(self, origin, t.Position, distance, ...)
            end
        end
        return origRC(self, origin, direction, distance, ...)
    end

    local origPP = util_mod.PlayParticles
    if origPP then
        util_mod.PlayParticles = function(self, obj)
            if typeof(obj) == "Instance" then
                local n = obj.Name:lower()
                if n:find("flash") or n:find("smoke")
                or n:find("blind") or n:find("muzzle") then return end
            end
            return origPP(self, obj)
        end
    end

    saHooked = true
    Library:Notify("SA hook applied", 2)
end

local function startSA()
    applySAHook()
    saFovCircle.Visible = SACFG.DrawFOV
end

local function stopSA()
    SACFG.On            = false
    saFovCircle.Visible = false
end

