local function getSilentTarget(origin)
    local center   = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local best, bestDist = nil, math.huge
    local myChar   = lp.Character
    for _, p in pairs(Players:GetPlayers()) do
        if p == lp then continue end
        local char = p.Character
        if not char or char == myChar then continue end
        local head = char:FindFirstChild("Head")
        local hum  = char:FindFirstChildOfClass("Humanoid")
        if not head or not hum or hum.Health <= 0 then continue end
        if (origin - head.Position).Magnitude > State.SilentMaxDist then continue end
        local sp, vis = Camera:WorldToViewportPoint(head.Position)
        if not vis then continue end
        local d = (Vector2.new(sp.X, sp.Y) - center).Magnitude
        if d < State.SilentFOV and d < bestDist then bestDist = d; best = head end
    end
    return best
end

local origRaycast = Utility.Raycast
Utility.Raycast = function(self, origin, direction, distance, ...)
    if State.SilentAim then
        local target = getSilentTarget(origin)
        if target then
            return origRaycast(self, origin, target.Position, distance, ...)
        end
    end
    return origRaycast(self, origin, direction, distance, ...)
end

local origParticles = Utility.PlayParticles
Utility.PlayParticles = function(self, obj)
    if State.SilentAim and typeof(obj) == "Instance" then
        local n = obj.Name:lower()
        if n:find("flash") or n:find("smoke") or n:find("blind") then return end
    end
    return origParticles(self, obj)
end

-- =============================================
--   WALLBANG — desync + cameradata override
-- =============================================

local WBDesync = { Active = false, Conn = nil, Task = nil }

local function wbDesyncStop()
    WBDesync.Active = false
    if WBDesync.Conn then WBDesync.Conn:Disconnect(); WBDesync.Conn = nil end
    if WBDesync.Task then task.cancel(WBDesync.Task); WBDesync.Task = nil end
    RunService:UnbindFromRenderStep("WBRestore")
end

local function wbDesyncStart(targetChar)
    if WBDesync.Conn then WBDesync.Conn:Disconnect() end
    WBDesync.Active = true
    WBDesync.Conn = RunService.Heartbeat:Connect(function()
        if not WBDesync.Active then return end
        local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        local tHead = targetChar and targetChar:FindFirstChild("Head")
        if not tHead then wbDesyncStop(); return end

        local savedCF  = hrp.CFrame
        local savedVel = hrp.AssemblyLinearVelocity
        local savedRot = hrp.AssemblyAngularVelocity

        -- Server sees character at target position (wall bypass)
        hrp.CFrame = tHead.CFrame * CFrame.new(0, -5, 0)

        -- Restore client-side immediately
        RunService:BindToRenderStep("WBRestore", 101, function()
            pcall(function()
                hrp.CFrame                  = savedCF
                hrp.AssemblyLinearVelocity  = savedVel
                hrp.AssemblyAngularVelocity = savedRot
            end)
            RunService:UnbindFromRenderStep("WBRestore")
        end)
    end)
end

-- Build wallbang cameradata with origin placed next to target
local function buildWBCameraData(targetChar)
    local partName = State.WallbangPart == "Head" and "Head" or "UpperTorso"
    local hitPart  = targetChar:FindFirstChild(partName)
                  or targetChar:FindFirstChild("HumanoidRootPart")
    if not hitPart then return nil, nil end

    local targetPos  = hitPart.Position
    local originPos  = targetPos - Vector3.new(0, 3, 0)
    local randOffset = hitPart.CFrame:ToObjectSpace(
        CFrame.new(targetPos + Vector3.new(
            math.random(-1, 1) * 0.5,
            math.random(-1, 1) * 0.5,
            math.random(-1, 1) * 0.5
        ))
    )

    local camdata = {}
    camdata[utf8.char(1)] = {
        [utf8.char(0)] = Utility:EncodeCFrame(CFrame.new(originPos, targetPos)),
        [utf8.char(1)] = Utility:EncodeCFrame(CFrame.new(targetPos)),
        [utf8.char(2)] = hitPart,
        [utf8.char(3)] = Utility:EncodeCFrame(randOffset),
    }

    wbDesyncStart(targetChar)
    if WBDesync.Task then task.cancel(WBDesync.Task) end
    WBDesync.Task = task.delay(0.15, wbDesyncStop)

    return camdata, hitPart
end

-- Hook Gun.StartShooting for normal (non-ragebot) shots
if GunModule and GunModule.StartShooting then
    local origSS = GunModule.StartShooting
    GunModule.StartShooting = function(self, ...)
        local results = { origSS(self, ...) }
        if not self.ClientFighter or not self.ClientFighter.IsLocalPlayer then
            return unpack(results)
        end
        if not State.Wallbang then return unpack(results) end
        local camdata = results[3]
        if not camdata or type(camdata) ~= "table" then return unpack(results) end

        local targetHead, targetChar = rageGetClosest()
        if not targetChar then return unpack(results) end

        local wbData = buildWBCameraData(targetChar)
        if not wbData then return unpack(results) end

        -- Inject wallbang data into existing table
        local inner    = camdata[utf8.char(1)]
        local wbInner  = wbData[utf8.char(1)]
        if inner and wbInner then
            for k, v in pairs(wbInner) do inner[k] = v end
        end

        return unpack(results)
    end
end

