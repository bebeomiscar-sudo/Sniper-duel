local equipped       = {}
local favorites      = {}
local lastUsedWeapon = nil
local saveFile       = "RivalsHub/cosmetics.json"

local function cloneCosmetic(name, cosType, options)
    if not CosmeticLibrary then return nil end
    local base = CosmeticLibrary.Cosmetics and CosmeticLibrary.Cosmetics[name]
    if not base then return nil end
    local data = {}
    for k, v in pairs(base) do data[k] = v end
    data.Name = name; data.Type = data.Type or cosType
    data.Seed = data.Seed or math.random(1, 1000000)
    if EnumLibrary then
        local ok, id = pcall(EnumLibrary.ToEnum, EnumLibrary, name)
        if ok and id then data.Enum = id; data.ObjectID = data.ObjectID or id end
    end
    if options then
        if options.inverted      ~= nil then data.Inverted         = options.inverted end
        if options.favoritesOnly ~= nil then data.OnlyUseFavorites = options.favoritesOnly end
    end
    return data
end

local function saveConfig()
    if not writefile then return end
    pcall(function()
        local config = { equipped = {}, favorites = favorites }
        for weapon, cosmetics in pairs(equipped) do
            config.equipped[weapon] = {}
            for ct, cd in pairs(cosmetics) do
                if cd and cd.Name then
                    config.equipped[weapon][ct] = { name = cd.Name, seed = cd.Seed, inverted = cd.Inverted }
                end
            end
        end
        if makefolder then makefolder("RivalsHub") end
        writefile(saveFile, HttpService:JSONEncode(config))
    end)
end

local function loadConfig()
    if not readfile or not isfile or not isfile(saveFile) then return end
    pcall(function()
        local config = HttpService:JSONDecode(readfile(saveFile))
        if config.equipped then
            for weapon, cosmetics in pairs(config.equipped) do
                equipped[weapon] = {}
                for ct, cd in pairs(cosmetics) do
                    local cloned = cloneCosmetic(cd.name, ct, { inverted = cd.inverted })
                    if cloned then cloned.Seed = cd.seed; equipped[weapon][ct] = cloned end
                end
            end
        end
        favorites = config.favorites or {}
    end)
end

