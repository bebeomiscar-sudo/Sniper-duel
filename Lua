-- =============================================
--   SINGLE __namecall HOOK (skin changer)
-- =============================================

local remotes        = ReplicatedStorage:FindFirstChild("Remotes")
local dataRemotes    = remotes and remotes:FindFirstChild("Data")
local equipRemote    = dataRemotes and dataRemotes:FindFirstChild("EquipCosmetic")
local favoriteRemote = dataRemotes and dataRemotes:FindFirstChild("FavoriteCosmetic")
local repRemotes     = remotes and remotes:FindFirstChild("Replication")
local fighterRemotes = repRemotes and repRemotes:FindFirstChild("Fighter")
local useItemRemote  = fighterRemotes and fighterRemotes:FindFirstChild("UseItem")

if hookmetamethod then
    local origNamecall
    origNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        if method ~= "FireServer" then return origNamecall(self, ...) end
        local args = { ... }

        if useItemRemote and self == useItemRemote then
            local objectID = args[1]
            pcall(function()
                local fighter = FighterController:GetFighter(lp)
                if fighter and fighter.Items then
                    for _, item in pairs(fighter.Items) do
                        if item:Get("ObjectID") == objectID then lastUsedWeapon = item.Name; break end
                    end
                end
            end)
        end

        if equipRemote and self == equipRemote then
            local weaponName, cosType, cosName, options = args[1], args[2], args[3], args[4] or {}
            if cosName and cosName ~= "None" and cosName ~= "" then
                local inv = DataController:Get("CosmeticInventory")
                if inv and rawget(inv, cosName) then return origNamecall(self, ...) end
            end
            equipped[weaponName] = equipped[weaponName] or {}
            if not cosName or cosName == "None" or cosName == "" then
                equipped[weaponName][cosType] = nil
                if not next(equipped[weaponName]) then equipped[weaponName] = nil end
            else
                local cloned = cloneCosmetic(cosName, cosType, {
                    inverted = options.IsInverted, favoritesOnly = options.OnlyUseFavorites
                })
                if cloned then equipped[weaponName][cosType] = cloned end
            end
            task.defer(function()
                pcall(function() DataController.CurrentData:Replicate("WeaponInventory") end)
                task.wait(0.2); saveConfig()
            end)
            return
        end

        if favoriteRemote and self == favoriteRemote then
            favorites[args[1]] = favorites[args[1]] or {}
            favorites[args[1]][args[2]] = args[3] or nil
            saveConfig()
            task.spawn(function()
                pcall(function() DataController.CurrentData:Replicate("FavoritedCosmetics") end)
            end)
            return
        end

        return origNamecall(self, ...)
    end)
end

