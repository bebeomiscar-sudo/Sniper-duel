local ALL_PARTS = {
    "Head", "HumanoidRootPart", "UpperTorso", "LowerTorso", "Torso",
    "LeftUpperArm", "LeftLowerArm", "LeftHand",
    "RightUpperArm", "RightLowerArm", "RightHand",
    "LeftUpperLeg", "LeftLowerLeg", "LeftFoot",
    "RightUpperLeg", "RightLowerLeg", "RightFoot",
}

local PART_PRESETS = {
    ["Head"]       = {"Head"},
    ["Torso"]      = {"UpperTorso", "Torso", "LowerTorso", "HumanoidRootPart"},
    ["UpperTorso"] = {"UpperTorso", "Torso", "HumanoidRootPart"},
    ["LowerTorso"] = {"LowerTorso", "Torso", "HumanoidRootPart"},
    ["Body"]       = {"UpperTorso", "LowerTorso", "Torso", "HumanoidRootPart"},
    ["Nearest"]    = {"Head", "UpperTorso", "LowerTorso", "HumanoidRootPart"},
    ["Random"]     = {"Random"},
}

local ALL_PART_OPTIONS = {
    "Head", "Torso", "UpperTorso", "LowerTorso", "Body", "Nearest", "Random"
}

local function getBestPart(char, setting)
    local preset = PART_PRESETS[setting] or {"Head"}
    if preset[1] == "Random" then
        local avail = {}
        for _, n in ipairs(ALL_PARTS) do
            local p = char:FindFirstChild(n)
            if p then table.insert(avail, p) end
        end
        return #avail > 0 and avail[math.random(1, #avail)] or nil
    end
    for _, n in ipairs(preset) do
        local p = char:FindFirstChild(n)
        if p then return p end
    end
    return nil
end

