-- MAIN LOOP
-- ═══════════════════════════════════════════
RunService.RenderStepped:Connect(function(dt)
    camera = Workspace.CurrentCamera
    local center = getScreenCenter()

    fovCircle.Position = center
    fovCircle.Radius   = getAimbotFOV()
    fovCircle.Visible  = AimbotCFG.DrawFOV and AimbotCFG.On
        and AimbotCFG.FOVStyle ~= "Invisible"

    saFovCircle.Position = center
    saFovCircle.Radius   = SACFG.FOV
    if SACFG.On and SACFG.DrawFOV then
        local myR = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        local has = saGetTarget(myR and myR.Position or camera.CFrame.Position) ~= nil
        saFovCircle.Color   = has
            and Color3.fromRGB(255, 50, 50)
            or  Color3.fromRGB(0, 200, 255)
        saFovCircle.Visible = true
    else
        saFovCircle.Visible = false
    end

    updateESP()

    if AimbotCFG.On then
        if isInReaction then
            reactionTimer = reactionTimer - dt
            if reactionTimer <= 0 then isInReaction = false end
        end

        if not isInReaction then
            if lockedTarget and not targetValid(lockedTarget) then
                lockedTarget = nil; lockTimer = 0; resetSmooth()
            end

            if not lockedTarget then
                local t = findTarget()
                if t then
                    lockedTarget  = t
                    lockTimer     = 0
                    isInReaction  = AimbotCFG.ReactionTime > 0
                    reactionTimer = AimbotCFG.ReactionTime / 1000
                    resetSmooth()
                end
            end

            if lockedTarget then
                lockTimer = lockTimer + dt
                if lockTimer > AimbotCFG.ForgotTime then
                    lockedTarget = nil; lockTimer = 0; resetSmooth()
                elseif isInFOV(lockedTarget) then
                    local pos = getSmoothedPos(lockedTarget, dt)
                    if pos then aimAt(pos, dt) end
                else
                    lockedTarget = nil; lockTimer = 0; resetSmooth()
                end
            end
        end
    end
end)

