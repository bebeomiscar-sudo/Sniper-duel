local function isAliveModel(model)
    if not model or not model.Parent then return false end
    local h = model:FindFirstChildOfClass("Humanoid")
    return h ~= nil and h.Health > 0
end

local function getClosestToMouse(fovDegrees)
    local mousePos = UserInputService:GetMouseLocation()
    local cam      = wspace.CurrentCamera
    local bestPart = nil
    local bestDist = math.huge
    local models   = FighterController:GetFighterModels(true)
    for _, model in pairs(models) do
        if not isAliveModel(model) then continue end
        local part = model:FindFirstChild(State.AimbotPart) or model:FindFirstChild("HumanoidRootPart")
        if not part then continue end
        local sp, onScreen = cam:WorldToScreenPoint(part.Position)
        if not onScreen then continue end
        local dist      = (Vector2.new(sp.X, sp.Y) - mousePos).Magnitude
        local fovRadius = (fovDegrees / 180) * math.min(cam.ViewportSize.X, cam.ViewportSize.Y) / 2
        if dist < fovRadius and dist < bestDist then bestDist = dist; bestPart = part end
    end
    return bestPart
end

-- =============================================
--   RAGEBOT HELPERS
-- =============================================

local ray_params  = RaycastParams.new()
local rageOffsets = {
    Vector3.new(0,12,0), Vector3.new(0,16,0), Vector3.new(0,20,0), Vector3.new(0,24,0),
    Vector3.new(0,28,0), Vector3.new(0,32,0), Vector3.new(0,36,0), Vector3.new(0,40,0),
}

function rageGetClosest()
    local char = lp.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil, nil end
    local target, targetChar, dist = nil, nil, math.huge
    for _, v in next, plrs:GetPlayers() do
        if v ~= lp and v.Character and v.Character:FindFirstChild("Head") then
            local mag = (char.HumanoidRootPart.Position - v.Character.Head.Position).Magnitude
            if mag < dist then dist = mag; target = v.Character.Head; targetChar = v.Character end
        end
    end
    return target, targetChar
end

local function rageCalculatePoint(origin, targetPos, targetChar)
    ray_params.FilterDescendantsInstances = { lp.Character, targetChar }
    ray_params.FilterType = Enum.RaycastFilterType.Exclude
    if not wspace:Raycast(origin, targetPos - origin, ray_params) then return origin, nil end
    for _, offset in next, rageOffsets do
        local scanPos = origin + offset
        if not wspace:Raycast(scanPos, targetPos - scanPos, ray_params) then
            return scanPos, offset.Y
        end
    end
    return nil, nil
end

