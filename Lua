-- UTILS
-- ═══════════════════════════════════════════
local function getScreenCenter()
    return Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
end

local function angleDiff(f, t)
    local d = t - f
    return ((d + math.pi) % (math.pi * 2)) - math.pi
end

local function isSameTeam(p)
    local same = false
    pcall(function()
        same = p.Team ~= nil and LP.Team ~= nil and p.Team == LP.Team
    end)
    return same
end

local visParams = RaycastParams.new()
visParams.FilterType = Enum.RaycastFilterType.Exclude

local function isVisible(origin, part)
    if not part then return false end
    local ok, res = pcall(function()
        visParams.FilterDescendantsInstances = {LP.Character, part.Parent}
        local hit = Workspace:Raycast(origin, part.Position - origin, visParams)
        return hit == nil or hit.Instance:IsDescendantOf(part.Parent)
    end)
    return ok and res or false
end

local function getAimbotFOV()
    local f = AimbotCFG.FOV
    if AimbotCFG.DynamicFOV then f = f * (camera.FieldOfView / 70) end
    return f
end

local function isInFOV(part)
    if not part then return false end
    local sp, on = camera:WorldToViewportPoint(part.Position)
    if not on then return false end
    return (Vector2.new(sp.X, sp.Y) - getScreenCenter()).Magnitude <= getAimbotFOV()
end

-- ═══════════════════════════════════════════
-- AIMBOT
-- ═══════════════════════════════════════════
local lockedTarget  = nil
local lockTimer     = 0
local reactionTimer = 0
local isInReaction  = false
local dX, dY, dZ   = nil, nil, nil

local function resetSmooth()
    dX, dY, dZ = nil, nil, nil
end

local function getSmoothedPos(part, dt)
    if not part or not part.Parent then resetSmooth(); return nil end

    local real = part.Position
    pcall(function()
        local hrp = part.Parent:FindFirstChild("HumanoidRootPart")
        if hrp and AimbotCFG.Prediction > 0 then
            real = real + hrp.AssemblyLinearVelocity * AimbotCFG.Prediction
        end
    end)

    if not dX then dX = real.X; dY = real.Y; dZ = real.Z; return real end

    local f  = 60 * dt
    local xA = math.clamp((1 - AimbotCFG.XSmooth) * (1 + f), 0.01, 1)
    local yA = math.clamp((1 - AimbotCFG.YSmooth) * (1 + f), 0.01, 1)
    local zA = math.clamp((1 - AimbotCFG.ZSmooth) * (1 + f), 0.01, 1)

    dX = dX + (real.X - dX) * xA
    dY = dY + (real.Y - dY) * yA
    dZ = dZ + (real.Z - dZ) * zA

    return Vector3.new(dX, dY, dZ)
end

local function targetValid(part)
    if not part or not part.Parent then return false end
    local hum = part.Parent:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if not isInFOV(part) then return false end
    if AimbotCFG.VisibleCheck and not isVisible(camera.CFrame.Position, part) then return false end
    if AimbotCFG.TeamCheck then
        local p = Players:GetPlayerFromCharacter(part.Parent)
        if p and isSameTeam(p) then return false end
    end
    return true
end

local function findTarget()
    local center = getScreenCenter()
    local fov    = getAimbotFOV()
    local best, bd = nil, fov
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LP then continue end
        if AimbotCFG.TeamCheck and isSameTeam(p) then continue end
        local ch = p.Character
        if not ch then continue end
        local hum = ch:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        local part = getBestPart(ch, AimbotCFG.TargetPart)
        if not part then continue end
        local sp, on = camera:WorldToViewportPoint(part.Position)
        if not on then continue end
        local d = (Vector2.new(sp.X, sp.Y) - center).Magnitude
        if d < fov and d < bd then
            if not AimbotCFG.VisibleCheck or isVisible(camera.CFrame.Position, part) then
                bd = d; best = part
            end
        end
    end
    return best
end

-- CFrame camera rotation — works PC and Mobile
-- No CameraController needed
local function aimAt(targetPos, dt)
    local sm     = math.clamp(1 / math.max(AimbotCFG.Smoothness, 0.1), 0.01, 1)
    local camPos = camera.CFrame.Position
    local dir    = (targetPos - camPos).Unit
    local goal   = CFrame.new(camPos, camPos + dir)
    local new    = camera.CFrame:Lerp(goal, sm)
    pcall(function() camera.CFrame = new end)
end

